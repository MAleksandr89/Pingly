# PostgreSQL
POSTGRES_USER=pingly
POSTGRES_PASSWORD=<your-password>
POSTGRES_DB=pingly

# Backend
DATABASE_URL=postgresql+asyncpg://pingly:<your-password>@postgres:5432/pingly
SECRET_KEY=<run: openssl rand -hex 32>
REDIS_URL=redis://redis:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173

# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Prod only
DOMAIN=pingly.example.com
ACME_EMAIL=admin@example.com
